@startuml
title Finesse Sportz - Modelo de Dados

hide circle
skinparam linetype ortho
skinparam shadowing false

entity "usuarios" as usuarios {
  * id : uuid <<PK>>
  --
  nome : varchar
  email : varchar <<UK>>
  senha_hash : varchar
  perfil : varchar
  ativo : boolean
}

entity "clientes" as clientes {
  * usuario_id : uuid <<PK, FK>>
  --
  telefone : varchar
  documento : varchar
}

entity "produtos" as produtos {
  * id : uuid <<PK>>
  --
  nome : varchar
  descricao : text
  modalidade : varchar
  time_nome : varchar
  preco_base : decimal
  ativo : boolean
}

entity "variacoes_produto" as variacoes {
  * id : uuid <<PK>>
  --
  produto_id : uuid <<FK>>
  sku : varchar <<UK>>
  tamanho : varchar
  cor : varchar
  quantidade_estoque : integer
  estoque_minimo : integer
}

entity "pedidos" as pedidos {
  * id : uuid <<PK>>
  --
  cliente_id : uuid <<FK>>
  cupom_id : uuid <<FK>>
  codigo : varchar <<UK>>
  status : varchar
  subtotal : decimal
  desconto : decimal
  frete : decimal
  total : decimal
  criado_em : timestamp
}

entity "itens_pedido" as itens {
  * id : uuid <<PK>>
  --
  pedido_id : uuid <<FK>>
  variacao_id : uuid <<FK>>
  quantidade : integer
  preco_unitario : decimal
  nome_personalizado : varchar
  numero_personalizado : integer
  valor_personalizacao : decimal
}

entity "pagamentos" as pagamentos {
  * id : uuid <<PK>>
  --
  pedido_id : uuid <<FK>>
  forma : varchar
  status : varchar
  valor : decimal
  transacao_externa : varchar
  criado_em : timestamp
}

entity "entregas" as entregas {
  * id : uuid <<PK>>
  --
  pedido_id : uuid <<FK>>
  cep : varchar
  endereco : varchar
  codigo_rastreio : varchar
  status : varchar
}

entity "cupons" as cupons {
  * id : uuid <<PK>>
  --
  codigo : varchar <<UK>>
  percentual : decimal
  valor_minimo : decimal
  validade : date
  ativo : boolean
}

usuarios ||--|| clientes
produtos ||--o{ variacoes
clientes ||--o{ pedidos
cupons ||--o{ pedidos
pedidos ||--|{ itens
variacoes ||--o{ itens
pedidos ||--|| pagamentos
pedidos ||--|| entregas

@enduml
